# Supagate environment template.
# Copy to .env for local Docker/dev use and replace placeholder values.

# Public values. These are also passed as Docker build args and are inlined
# into the Next.js client bundle, so do not put secrets here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Set for cross-subdomain sessions, for example:
# COOKIE_DOMAIN=.example.com
COOKIE_DOMAIN=

# Server-side secrets.
RESEND_API_KEY=your-resend-api-key
HEALTH_CHECK_TOKEN=replace-with-a-long-random-token
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPAGATE_ADMIN_EMAILS=you@example.com
